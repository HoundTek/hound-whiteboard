        "128x128.png",
        "128x128@2x.png",
        "icon.png",
        "icon.ico",
        "StoreLogo.png",
        "Square30x30Logo.png",
        "Square44x44Logo.png",
        "Square71x71Logo.png",
        "Square89x89Logo.png",
        "Square107x107Logo.png",
