      "initCommand": "yarn init:android"
    },
    "ios": {
      "source": ["icon-ios.png", "icon.png"],
      "output": "src-tauri/gen/ios",
      "needsInit": true,
      "initCheckPath": "src-tauri/gen/ios",
      "initCommand": "yarn init:ios"
    }
