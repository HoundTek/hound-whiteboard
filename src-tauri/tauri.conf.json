{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Hound Whiteboard",
  "identifier": "com.hound.whiteboard",
  "version": "0.0.1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": null,
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "url": "demo/whiteboard.html",
        "title": "Hound Whiteboard",
        "width": 800,
        "height": 600,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://tauri.localhost http://tauri.localhost",
      "capabilities": [
        {
          "identifier": "main-default",
          "windows": ["main"],
          "permissions": ["core:default"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "nsis": null,
      "wix": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {},
      "rpm": {}
    }
  }
}