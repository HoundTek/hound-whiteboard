    "adm-zip": "0.5.17",
    "hidefile": "3"
  },
  "devDependencies": {
    "hound-tauri-build": "0.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "benchmark": "2.1.4",
    "husky": "^9.1.7",
    "jest": "30.4.2",
    "react": "18"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/src/core/test-support/jest-setup.js"]
