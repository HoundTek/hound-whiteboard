{
  "name": "hound-whiteboard",
  "version": "0.0.1",
  "type": "module",
  "description": "A whiteboard app",
  "scripts": {
    "deps": "yarn",
    "icon": "hound-tauri-build icon all",
    "icon:desktop": "hound-tauri-build icon desktop",
    "icon:mac": "hound-tauri-build icon mac",
    "icon:win": "hound-tauri-build icon win",
    "icon:linux": "hound-tauri-build icon linux",
    "icon:android": "hound-tauri-build icon android",
    "icon:ios": "hound-tauri-build icon ios",
    "clean": "hound-tauri-clean",
    "clean:target": "hound-tauri-clean target",
    "clean:gen": "hound-tauri-clean gen",
    "clean:icons": "hound-tauri-clean icons",
    "clean:temp": "hound-tauri-clean temp",
    "clean:status": "hound-tauri-clean status",
    "clean:help": "hound-tauri-clean help",
    "dev": "hound-tauri-build dev",
    "build": "hound-tauri-build build",
    "build:quick": "hound-tauri-build build-quick",
    "dev:win": "hound-tauri-build dev win",
    "build:win": "hound-tauri-build build win",
    "dev:mac": "hound-tauri-build dev mac",
    "build:mac": "hound-tauri-build build mac",
    "build:mac-universal": "hound-tauri-build build mac-universal",
    "dev:linux": "hound-tauri-build dev linux",
    "build:linux": "hound-tauri-build build linux",
    "init:android": "yarn deps && tauri android init",
    "dev:android": "hound-tauri-build dev android",
    "build:android": "hound-tauri-build build android",
    "dev:ios": "hound-tauri-build dev ios",
    "build:ios": "hound-tauri-build build ios",
    "build:desktop-platforms": "hound-tauri-build build desktop-platforms",
    "build:mobile": "hound-tauri-build build mobile",
    "build:all": "hound-tauri-build build all",
    "test": "node --experimental-vm-modules --localstorage-file=/tmp/jest-localstorage node_modules/jest/bin/jest.js --passWithNoTests",
    "ship": "hound-tauri-build ship",
    "ship:win": "hound-tauri-build ship win",
    "ship:mac": "hound-tauri-build ship mac",
    "ship:linux": "hound-tauri-build ship linux",
    "ship:android": "hound-tauri-build ship android",
    "ship:ios": "hound-tauri-build ship ios",
    "ship:desktop-platforms": "hound-tauri-build ship desktop-platforms",
    "ship:mobile": "hound-tauri-build ship mobile",
    "ship:all": "hound-tauri-build ship all",
    "bench": "node benchmarks/all.bench.js",
    "bench:io:direct": "node benchmarks/io-direct.bench.js",
    "bench:io:granularity": "node benchmarks/io-file-granularity.bench.js",
    "bench:worker": "node benchmarks/worker-rpc.bench.js",
    "bench:render": "node benchmarks/worker-render.bench.js",
    "check:docs": "node scripts/ci/check-doc-links.mjs",
    "check:modules": "node scripts/ci/check-module-paths.mjs",
    "ci-check": "yarn check:docs && yarn check:modules",
    "prepare": "husky"
  },
  "author": "Frank Steven",
  "contributors": [
    {
      "name": "Zhou Chenyu",
      "email": "zhouc_yu@foxmail.com"
    }
  ],
  "license": "GPL-3.0-only",
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "adm-zip": "0.5.17",
    "hidefile": "3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "benchmark": "2.1.4",
    "hound-tauri-build": "0.2.2",
    "husky": "^9.1.7",
    "ink": "5",
    "jest": "30.4.2",
    "react": "18"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/src/core/test-support/jest-setup.js"]
  }
}
