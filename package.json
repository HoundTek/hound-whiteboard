    "icon:mac": "htb icon mac",
    "icon:win": "htb icon win",
    "icon:linux": "htb icon linux",
    "icon:android": "htb icon android",
    "icon:ios": "htb icon ios",
    "clean": "htb-clean",
    "clean:target": "htb-clean target",
    "clean:gen": "htb-clean gen",
    "clean:icons": "htb-clean icons",
    "clean:temp": "htb-clean temp",
    "clean:status": "htb-clean status",
    "clean:help": "htb-clean help",
    "dev": "htb dev",
    "build": "htb build",
    "build:quick": "htb build-quick",
    "dev:win": "htb dev win",
    "build:win": "htb build win",
    "dev:mac": "htb dev mac",
    "build:mac": "htb build mac",
    "build:mac-universal": "htb build mac-universal",
    "dev:linux": "htb dev linux",
    "build:linux": "htb build linux",
    "init:android": "yarn deps && tauri android init",
    "dev:android": "htb dev android",
    "build:android": "htb build android",
    "dev:ios": "htb dev ios",
    "build:ios": "htb build ios",
    "build:desktop-platforms": "htb build desktop-platforms",
    "build:mobile": "htb build mobile",
    "build:all": "htb build all",
    "test": "node --experimental-vm-modules --localstorage-file=/tmp/jest-localstorage node_modules/jest/bin/jest.js --passWithNoTests",
    "ship": "htb ship",
    "ship:win": "htb ship win",
    "ship:mac": "htb ship mac",
    "ship:linux": "htb ship linux",
    "ship:android": "htb ship android",
    "ship:ios": "htb ship ios",
    "ship:desktop-platforms": "htb ship desktop-platforms",
    "ship:mobile": "htb ship mobile",
    "ship:all": "htb ship all",
    "bench": "node benchmarks/all.bench.js",
    "bench:io:direct": "node benchmarks/io-direct.bench.js",
    "bench:io:granularity": "node benchmarks/io-file-granularity.bench.js",
    "bench:worker": "node benchmarks/worker-rpc.bench.js",
    "bench:render": "node benchmarks/worker-render.bench.js",
    "check:docs": "node scripts/ci/check-doc-links.mjs",
    "check:modules": "node scripts/ci/check-module-paths.mjs",
